{
  "name": "nexio-api",
  "type": "module",
  "scripts": {
    "dev": "pnpm exec dotenv -e .env -- tsx watch src/server.ts",
    "build": "rimraf dist && tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json",
    "start": "cross-env NODE_ENV=production node dist/server.js",
    "typecheck": "tsc --noEmit",
    "lint": "biome lint ./src",
    "lint:fix": "biome lint --write ./src",
    "format": "biome format --write ./src",
    "check": "biome check --write ./src",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepare": "husky",
    "dz:generate": "pnpm exec drizzle-kit generate",
    "dz:migrate": "pnpm exec drizzle-kit migrate",
    "dz:push": "pnpm exec drizzle-kit push",
    "dz:studio": "pnpm exec drizzle-kit studio"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "3.1014.0",
    "@aws-sdk/s3-request-presigner": "3.1014.0",
    "@hono/node-server": "^1.19.11",
    "@hono/zod-openapi": "1.2.3",
    "@neondatabase/serverless": "1.0.2",
    "@scalar/hono-api-reference": "0.10.5",
    "better-auth": "1.5.6",
    "better-auth-localization": "3.0.0",
    "dayjs": "1.11.20",
    "drizzle-kit": "0.31.10",
    "drizzle-orm": "0.45.1",
    "groq-sdk": "1.1.1",
    "hono": "^4.12.8",
    "mammoth": "1.12.0",
    "pdf-parse": "2.4.5",
    "pg": "8.20.0",
    "pg-boss": "12.14.0",
    "pino": "10.3.1",
    "pino-pretty": "13.1.3",
    "puppeteer": "24.40.0",
    "ws": "8.20.0",
    "zod": "^4.3.6"
  },
  "engines": {
    "node": ">=24.14.0",
    "pnpm": ">=10.30.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "@commitlint/config-conventional": "^20.5.0",
    "@types/node": "^20.11.17",
    "@types/pg": "8.20.0",
    "@types/pino": "7.0.5",
    "@types/ws": "8.18.1",
    "@vitest/coverage-v8": "^4.1.0",
    "commitlint": "^20.5.0",
    "cross-env": "^10.1.0",
    "dotenv-cli": "^11.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "rimraf": "^6.1.3",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.7.1",
    "typescript": "^5.8.3",
    "vitest": "^4.1.0"
  }
}