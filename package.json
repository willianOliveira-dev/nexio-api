{
  "name": "nexio-api",
  "type": "module",
  "scripts": {
    "dev": "pnpm exec dotenv -e .env -- tsx watch src/server.ts",
    "build": "rimraf dist && tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json",
    "start": "cross-env NODE_ENV=production node dist/server.js",
    "typecheck": "tsc --noEmit",
    "lint": "biome lint ./src",
    "lint:fix": "biome lint --write ./src",
    "format": "biome format --write ./src",
    "check": "biome check --write ./src",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepare": "husky"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.11",
    "@hono/zod-validator": "^0.7.6",
    "hono": "^4.12.8",
    "zod": "^4.3.6"
  },
  "engines": {
    "node": ">=24.14.0",
    "pnpm": ">=10.30.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "@commitlint/config-conventional": "^20.5.0",
    "@types/node": "^20.11.17",
    "@vitest/coverage-v8": "^4.1.0",
    "commitlint": "^20.5.0",
    "cross-env": "^10.1.0",
    "dotenv-cli": "^11.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "rimraf": "^6.1.3",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.7.1",
    "typescript": "^5.8.3",
    "vitest": "^4.1.0"
  }
}